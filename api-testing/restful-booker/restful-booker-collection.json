              "});\r",
              "\r",
              "pm.test(\"booking dates are present\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.bookingdates.checkin).to.not.be.undefined;\r",
              "    pm.expect(jsonData.bookingdates.checkout).to.not.be.undefined;\r",
              "});"
            ],

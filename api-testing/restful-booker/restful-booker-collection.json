    {
      "name": "Create booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Booking ID is present\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.bookingid).to.not.be.undefined;\r",
              "    pm.environment.set(\"booking_id\", jsonData.bookingid);\r",
              "});\r",
              "\r",
              "pm.test(\"Firstname is correct\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.booking.firstname).to.eql(\"Nabilah\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
